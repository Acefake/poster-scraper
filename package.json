{
  "name": "posterscraper",
  "version": "1.0.0",
  "description": "An Electron application with Vue and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev:backend": "cd packages/services/backend && go run .",
    "dev": "concurrently -k -n BACKEND,APP -c yellow,cyan \"pnpm dev:backend\" \"electron-vite dev\"",
    "build:nocheck": "electron-vite build",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:backend": "cd packages/services/backend && go build -o main.exe .",
    "build:unpack": "npm run build:nocheck && npm run build:backend && electron-builder --dir",
    "build:win": "npm run build:nocheck && npm run build:backend && electron-builder --win",
    "build:mac": "npm run build:nocheck && electron-builder --mac",
    "build:linux": "npm run build:nocheck && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@tdanks2000/tmdb-wrapper": "^1.3.3",
    "@types/crypto-js": "^4.2.2",
    "@vueuse/core": "^14.2.1",
    "ant-design-vue": "4.x",
    "axios": "^1.15.2",
    "cheerio": "^1.2.0",
    "crypto-js": "^4.2.0",
    "electron-updater": "^6.3.9",
    "hls.js": "^1.6.16",
    "pinia": "^3.0.3",
    "vue-router": "^4.5.1"
  },
  "build": {
    "win": {
      "target": ["portable", "zip"]
    },
    "extraResources": [
      {
        "from": "packages/services/backend/main.exe",
        "to": "backend/main.exe"
      },
      {
        "from": "packages/services/backend/py",
        "to": "backend/py"
      }
    ]
  },
  "devDependencies": {
    "@egoist/tailwindcss-icons": "^1.9.0",
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@iconify-json/mdi": "^1.2.3",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/node": "^22.16.5",
    "@vitejs/plugin-vue": "^6.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^37.2.3",
    "electron-builder": "^25.1.8",
    "electron-vite": "^4.0.0",
    "eslint": "^9.31.0",
    "eslint-plugin-vue": "^10.3.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "vite": "^7.0.5",
    "vue": "^3.5.17",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.0.3"
  }
}
